{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM","ES2020"],
    "jsx": "react-jsx",
    "module": "node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["react", "react-dom"]
  },
  "include": ["src"]
}