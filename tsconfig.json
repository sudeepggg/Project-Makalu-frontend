{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",                // <--- Change this
    "moduleResolution": "bundler",      // <--- Change this for Vite
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["react", "react-dom", "vite/client"]
  },
  "include": ["src"]
}